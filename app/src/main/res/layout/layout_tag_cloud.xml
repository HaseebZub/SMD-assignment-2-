<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:layout_margin="8dp"
    android:background="@drawable/bg_card">

    <TextView
        android:id="@+id/tv_tag_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Device Categories"
        android:textStyle="bold"
        android:textColor="@color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Requirement 10: ConstraintLayout Flow Helper -->
    <androidx.constraintlayout.helper.widget.Flow
        android:id="@+id/flow_tags"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tv_tag_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:flow_wrapMode="aligned"
        app:flow_horizontalGap="8dp"
        app:flow_verticalGap="8dp"
        app:constraint_referenced_ids="tag_security,tag_lighting,tag_climate,tag_entertainment,tag_kitchen,tag_garden" />

    <TextView
        android:id="@+id/tag_security"
        style="@style/TagStyle"
        android:text="Security" />

    <TextView
        android:id="@+id/tag_lighting"
        style="@style/TagStyle"
        android:text="Lighting" />

    <TextView
        android:id="@+id/tag_climate"
        style="@style/TagStyle"
        android:text="Climate" />

    <TextView
        android:id="@+id/tag_entertainment"
        style="@style/TagStyle"
        android:text="Entertainment" />

    <TextView
        android:id="@+id/tag_kitchen"
        style="@style/TagStyle"
        android:text="Kitchen" />

    <TextView
        android:id="@+id/tag_garden"
        style="@style/TagStyle"
        android:text="Garden" />

</androidx.constraintlayout.widget.ConstraintLayout>